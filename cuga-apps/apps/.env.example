# ============================================================================
# cuga-apps (MCP edition) — shared environment file
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#   python3 launch.py          # starts all MCP servers + apps with these env vars
#
# All apps and MCP servers inherit every variable below. App-specific variables
# only apply to the processes that read them — unused variables are silently
# ignored.
# ============================================================================


# ── LLM provider ─────────────────────────────────────────────────────────────
# Used by: all apps (MCP servers do not make LLM calls)
# Options: rits | watsonx | anthropic | openai | ollama | litellm
LLM_PROVIDER=rits
LLM_MODEL=gpt-oss-120b


# ── Anthropic ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── RITS (IBM Research Inference-to-Service) ──────────────────────────────────
# RITS_API_KEY=<your key>
# RITS_BASE_URL=https://inference-3scale-apicast-production.apps.rits.fmaas.res.ibm.com


# ── watsonx.ai ────────────────────────────────────────────────────────────────
# WATSONX_APIKEY=your_watsonx_api_key_here
# WATSONX_PROJECT_ID=your_project_id_here
# WATSONX_SPACE_ID=your_space_id_here
# WATSONX_URL=https://us-south.ml.cloud.ibm.com


# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here


# ── Ollama (local, no key needed) ─────────────────────────────────────────────
# OLLAMA_BASE_URL=http://host.docker.internal:11434


# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
# LITELLM_API_KEY=your_litellm_api_key_here
# LITELLM_BASE_URL=https://your-litellm-proxy/


# ── MCP server URLs ───────────────────────────────────────────────────────────
# Where each app's _mcp_bridge connects. Defaults below work for docker compose
# (service DNS) AND localhost dev — the bridge picks the right one based on
# whether it's running inside the docker network.
#
# Override only if you run MCP servers somewhere unusual.
# MCP_WEB_URL=http://mcp-web:29100/mcp
# MCP_KNOWLEDGE_URL=http://mcp-knowledge:29101/mcp
# MCP_GEO_URL=http://mcp-geo:29102/mcp
# MCP_FINANCE_URL=http://mcp-finance:29103/mcp
# MCP_CODE_URL=http://mcp-code:29104/mcp
# MCP_LOCAL_URL=http://mcp-local:29105/mcp


# ── Third-party API keys consumed by MCP servers ─────────────────────────────
# Tavily — required by mcp-web's web_search tool
# Sign up: https://tavily.com
TAVILY_API_KEY=<your key>

# Alpha Vantage — required by mcp-finance's get_stock_quote tool
# Sign up: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=<your key>

# OpenTripMap — required by mcp-geo's search_attractions tool (free tier, 500/day)
# Sign up: https://opentripmap.io/product
OPENTRIPMAP_API_KEY=<your key>


# ── Email / SMTP (optional — used by apps that send digests/alerts) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_USERNAME=<>
SMTP_PASSWORD=<>

ALERT_TO=<>
DIGEST_TO=<>
RESEARCH_TO=<>


# ── Voice / Whisper (voice_journal, stage 2) ─────────────────────────────────
# WHISPER_MODEL=base


# ── Server monitor thresholds (optional — built-in defaults) ─────────────────
# CPU_THRESHOLD=75
# CPU_CRITICAL=90
# RAM_THRESHOLD=80
# RAM_CRITICAL=92
# DISK_THRESHOLD=80
# DISK_CRITICAL=90
# POLL_INTERVAL_SECONDS=60
# ALERT_COOLDOWN_SECONDS=900


# ── Drop summarizer watch directory (stage 2) ────────────────────────────────
# WATCH_DIR=/path/to/your/inbox
# POLL_SECONDS=15


# ── No key needed (MCP servers use these for free) ──────────────────────────
# Wikipedia REST API  — https://en.wikipedia.org/api/rest_v1/
# wttr.in weather     — https://wttr.in/:help
# Nominatim geocoding — https://nominatim.openstreetmap.org/
# arXiv + Semantic Scholar — https://arxiv.org/help/api + https://api.semanticscholar.org/
# CoinGecko crypto prices — https://www.coingecko.com/en/api
